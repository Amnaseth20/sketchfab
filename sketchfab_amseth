<!DOCTYPE html>
<html>
<head>
  <title>Sketchfab Model with Voiceover</title>

  <style>
    body {
      margin: 0;
      background: #111;
      font-family: Arial, sans-serif;
      overflow: hidden;
    }

    iframe {
      width: 100vw;
      height: 100vh;
      border: none;
    }

    .audio-button {
      position: fixed;
      top: 15px;
      left: 15px;
      z-index: 10;
      padding: 12px 16px;
      background: #1caad9;
      color: white;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;
    }

    .audio-button:hover {
      background: #1596bf;
    }
  </style>
</head>

<body>

<button class="audio-button" onclick="playVoice()">
  ▶ Play Voiceover
</button>

<iframe
  src="https://sketchfab.com/models/ade205f1823d4d47b45d6cfb7b822311/embed"
  allow="autoplay; fullscreen; xr-spatial-tracking">
</iframe>

<audio id="voiceover" preload="auto">
  <source src="amna.mp3" type="audio/mpeg">
</audio>

<script>
function playVoice() {
  const audio = document.getElementById("voiceover");
  audio.currentTime = 0;
  audio.play();
}
</script>

</body>
</html>
