<!DOCTYPE html>
<html>
<head>
  <title>Sketchfab Voiceover Project</title>

  <style>
    body {
      margin: 0;
      background: #111;
      font-family: Arial, sans-serif;
      overflow: hidden;
    }

    iframe {
      width: 100vw;
      height: 100vh;
      border: none;
    }

    .overlay {
      position: fixed;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.85);
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: 10;
    }

    .btn {
      padding: 15px 25px;
      font-size: 18px;
      background: #1caad9;
      border: none;
      color: white;
      border-radius: 8px;
      cursor: pointer;
    }

    .btn:hover {
      background: #1596bf;
    }
  </style>
</head>

<body>

<!-- Start Screen -->
<div class="overlay" id="overlay">
  <button class="btn" onclick="startExperience()">
    ▶ Start Experience
  </button>
</div>

<!-- Sketchfab Model -->
<iframe
  src="https://sketchfab.com/models/ade205f1823d4d47b45d6cfb7b822311/embed"
  allow="autoplay; fullscreen; xr-spatial-tracking">
</iframe>

<!-- Audio -->
<audio id="voiceover" preload="auto">
  <source src="amna.mp3" type="audio/mpeg">
</audio>

<script>
function startExperience() {
  document.getElementById("overlay").style.display = "none";
  const audio = document.getElementById("voiceover");
  audio.play();
}
</script>

</body>
</html>
